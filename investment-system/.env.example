# ============================================================
# 日本株投資分析システム - 環境変数設定テンプレート
# このファイルを .env にコピーして各値を設定してください
# cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Anthropic API (必須)
# 取得先: https://console.anthropic.com/
# ----------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------
# EDINET API (必須)
# 取得先: https://disclosure2.edinet-fsa.go.jp/weee0010.aspx
# ----------------------------------------------------------
EDINET_API_KEY=your_edinet_api_key_here

# ----------------------------------------------------------
# Slack Webhook (任意 - アラート通知用)
# 取得先: https://api.slack.com/apps -> Incoming Webhooks
# ----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ----------------------------------------------------------
# アプリケーション設定
# ----------------------------------------------------------
# ログレベル: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# データ保存ディレクトリ
DATA_DIR=./data

# 分析対象の市場 (tokyo)
TARGET_MARKET=tokyo

# スクリーニング対象の最小時価総額（億円）
MIN_MARKET_CAP=100

# ポートフォリオ最大銘柄数
MAX_PORTFOLIO_SIZE=20

# Claude モデル設定
CLAUDE_MODEL=claude-opus-4-6

# ----------------------------------------------------------
# DuckDB 設定
# ----------------------------------------------------------
DUCKDB_PATH=./data/processed/investment.duckdb

# ----------------------------------------------------------
# スケジュール設定
# ----------------------------------------------------------
# 日次更新時刻 (HH:MM形式, JST)
DAILY_UPDATE_TIME=08:00

# 週次レポート送信曜日 (0=月曜, 6=日曜)
WEEKLY_REPORT_DAY=0

# 週次レポート送信時刻
WEEKLY_REPORT_TIME=07:00
